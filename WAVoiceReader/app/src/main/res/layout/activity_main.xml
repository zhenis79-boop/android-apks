<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WA Voice Reader"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Автоматическая расшифровка голосовых WhatsApp"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#11000000"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:text="Статус загружается…" />

        <Button
            android:id="@+id/btnAllFilesAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Разрешить доступ ко всем файлам" />

        <Button
            android:id="@+id/btnOverlayPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2. Разрешить показ поверх экрана" />

        <Button
            android:id="@+id/btnNotifPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="3. Разрешить уведомления" />

        <Button
            android:id="@+id/btnNotifAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Доступ к уведомлениям (кто прислал голосовое)" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="4. OpenAI API-ключ:" />

        <EditText
            android:id="@+id/editApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-..."
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnSaveKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Сохранить ключ" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#25D366"
            android:text="▶ Запустить слежение" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="■ Остановить" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Тест без WhatsApp:"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="12sp"
            android:text="Запишет 3 секунды с микрофона и положит файл в ту же папку, которую слушает сервис — будто пришло настоящее голосовое. Сначала запустите слежение выше." />

        <Button
            android:id="@+id/btnTestRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#128C7E"
            android:text="🎤 Тестовое голосовое (эмуляция WhatsApp)" />

        <!-- История распознаваний -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="История распознанных сообщений:"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            android:background="#11000000">

            <TextView
                android:id="@+id/textHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textSize="13sp"
                android:text="(история пуста)" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnCopyHistory"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Копировать историю" />

            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Очистить" />
        </LinearLayout>

        <!-- Временно: логи для диагностики бага с отправителем -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Логи (временно, для диагностики):"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            android:background="#11000000">

            <TextView
                android:id="@+id/textLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:text="(лог пуст)" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnCopyLogs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Копировать логи" />

            <Button
                android:id="@+id/btnRefreshLogs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Обновить" />

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Очистить" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
